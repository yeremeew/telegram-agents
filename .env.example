# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Your server's public URL (no trailing slash)
# e.g. https://telegram-agents.up.railway.app
WEBHOOK_BASE_URL=https://your-server.com

PORT=3000

# ── Bot Tokens ────────────────────────────────────────────────────────────────
# Add a token for each agent you've created via @BotFather.
# Leave blank or omit any agent you haven't set up yet — it will be skipped.

